{
  "expo": {
    "name": "Whats Cooking",
    "slug": "whats-cooking",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "android": {
      "package": "com.yourname.whatscooking",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B35"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.whatscooking",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Whats Cooking uses your location to find restaurants near you.",
        "NSLocationAlwaysUsageDescription": "Whats Cooking uses your location to find restaurants near you."
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Whats Cooking uses your location to find restaurants near you."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Whats Cooking needs access to your photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF6B35"
        }
      ],
      "expo-system-ui"
    ],
    "extra": {
      "eas": {
        "projectId": "15062ebe-c1c0-4d13-9bf4-bcce99cc9e62"
      }
    }
  }
}